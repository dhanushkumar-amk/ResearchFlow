# Production Server Configuration
PORT=3001
NODE_ENV=production

# Authentication (Mandatory)
JWT_SECRET=researchflow_secure_jwt_secret_2025
FRONTEND_URL=http://localhost:3000

# LLM Inference
GROQ_API_KEY=gsk_your_key_here
GOOGLE_API_KEY=AIza_your_key_here

# Intelligence Engine (Search)
TAVILY_API_KEY=tvly_your_key_here

# Persistence Layer (Neon / Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Caching Layer (Upstash / Redis)
UPSTASH_REDIS_REST_URL=https://your_instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Memory Backend (Qdrant)
QDRANT_URL=https://your_cluster.cloud.qdrant.io
QDRANT_API_KEY=your_cluster_api_key_here
